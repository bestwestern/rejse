console.log(files)
const entries = Object.entries(files).sort(([pathA], [pathB]) => {
  const a = meta.get(pathA.split("/").pop()!);
  const b = meta.get(pathB.split("/").pop()!);
  if (a&&b){
    console.log("bingo")
return metaarray.indexOf(a.file)-metaarray.indexOf(b.file);

  }
  return (
    (b?.year ?? 0) - (a?.year ?? 0) ||
    (b?.month ?? 0) - (a?.month ?? 0) ||
    (b?.location ?? "").localeCompare(a?.location ?? "") ||
    pathB.localeCompare(pathA, undefined, { numeric: true })
  );
});
const entries_new=Object.entries(files);
function describe(e: GalleryPhoto | undefined): string {
  if (!e) return "";
  const loc = e.location.trim();
  return loc;
}

// Fallback alt text from the filename ("01-snowy-harbor.jpg" -> "Snowy harbor")
// for photos without a description yet, so alt / SEO text is never empty.
function captionFor(path: string, index: number): string {
  const base = path
    .split("/")
    .pop()!
    .replace(/\.[^.]+$/, "");
  const words = base
    .replace(/^[\s\d_-]+/, "")
    .replace(/[-_]+/g, " ")
    .trim();
  if (!words) return `Photograph ${index + 1}`;
  return words.charAt(0).toUpperCase() + words.slice(1);
}

const photos = await Promise.all(
  entries.map(async ([path, mod], i) => {
    const photo = await renderPhoto(mod.default);
    const entry = meta.get(path.split("/").pop()!);
    const caption = describe(entry);
    return { ...photo, caption, alt: caption || captionFor(path, i), entry };
  }),
);
// Structured data: an ImageGallery of ImageObjects attributed to the photographer.
// When a photo has a description, mirror the Calendar's richer metadata
// (caption, date, place).
const base = Astro.site ? Astro.site.href.replace(/\/$/, "") : "";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: `${collection.charAt(0).toUpperCase() + collection.slice(1)} — ${siteInfo.name}`,
  url: `${base}${Astro.url.pathname}`,
  isPartOf: { "@id": `${base}/#website` },
  author: { "@id": `${base}/#person` },
  image: photos.map((p) => ({
    "@type": "ImageObject",
    contentUrl: `${base}${p.full}`,
    name: p.alt,
    ...(p.caption ? { caption: p.caption } : {}),
    ...(p.entry && p.entry.month >= 1 && p.entry.month <= 12 && p.entry.year > 0
      ? {
          dateCreated: `${p.entry.year}-${String(p.entry.month).padStart(2, "0")}`,
        }
      : {}),
    ...(p.entry && p.entry.location.trim()
      ? { contentLocation: { "@type": "Place", name: p.entry.location.trim() } }
      : {}),
    creator: { "@id": `${base}/#person` },
    copyrightHolder: { "@id": `${base}/#person` },
    creditText: siteInfo.name,
    copyrightNotice: `© ${siteInfo.name}`,
    license: `${base}/license`,
    acquireLicensePage: `${base}/contact`,
  })),
};
